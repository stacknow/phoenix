{application,hello_world,
    [{compile_env,
         [{hello_world,['Elixir.HelloWorldWeb.Gettext'],error},
          {hello_world,[dev_routes],{ok,true}}]},
     {applications,
         [kernel,stdlib,elixir,logger,runtime_tools,phoenix,
          phoenix_live_dashboard,esbuild,tailwind,swoosh,finch,
          telemetry_metrics,telemetry_poller,gettext,jason,dns_cluster,
          bandit]},
     {description,"hello_world"},
     {modules,
         ['Elixir.HelloWorld','Elixir.HelloWorld.Application',
          'Elixir.HelloWorld.Mailer','Elixir.HelloWorldWeb',
          'Elixir.HelloWorldWeb.Endpoint','Elixir.HelloWorldWeb.ErrorJSON',
          'Elixir.HelloWorldWeb.Gettext',
          'Elixir.HelloWorldWeb.PageController','Elixir.HelloWorldWeb.Router',
          'Elixir.HelloWorldWeb.Telemetry']},
     {registered,[]},
     {vsn,"0.1.0"},
     {mod,{'Elixir.HelloWorld.Application',[]}}]}.
